y_0 = -60;
e10 = pi/2;
e20 = 0;
e10_hat = e10;
e20_hat = e20;
e30_hat = 0.05;
err_10 = e10 - e10_hat;
err_20 = e20 - e20_hat;
x60 = 0.1;
x70 = 0.2;
% [kai0,kaidot0] = get_initial(xa_0,ya_0);
% x_initial = [xa_0;ya_0;(kai0);kaidot0];

x_initial = [x_0;y_0;e10;e20;e10_hat;e20_hat;err_10;err_20;x60;x70];

options = odeset('RelTol',1e-8,'AbsTol',1e-8);
[t,x] = ode45(@(t,x)fun_parabola(t,x,u,v,Time,a) ,tspan, x_initial,options);
x_ini = x(1,1) ;
y_ini = x(1,2) ;
x_end = x(end,1) ;
y_end = x(end,2) ;

[kai_p,kai_o,kai_des, kaidot_des] = fun_propkaid(x(:,1),x(:,2),a);
kai = x(:,3) + kai_des ;
% Vg = Wx.*cos(kai) + Wy.*sin(kai) + sqrt(Va^2 - (Wx.*sin(kai) - Wy.*cos(kai))) ;
V_g = get_Vg(t,kai,u,v,Time);
kappa_des = kaidot_des./V_g ;
e_path = -((x(:,2) - k) - a_arr.*(x(:,1) - h).^2);

for i = 1:length(t)
    if abs(e_path(i,1))  <= 0.1
%         c(i) = abs(e_path(i,1)) ;
        c_arr = [c_arr abs(e_path(i,1))];
    else
        c_tran =[c_tran abs(e_path(i,1))];
%         c_arr_col(j,:) = c_arr ;
    end
    
end

% rmse_z = rms(c);
tran_z(i) = mean(c_tran);
ss_z(i) = mean(c_arr);

